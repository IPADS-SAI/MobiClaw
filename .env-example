# Seneschal runtime settings
export SENESCHAL_LOG_LEVEL="INFO"

# ===== LLM provider (required) =====
# Used by Seneschal + WeKnora model definitions (KnowledgeQA / VLM).
# Fill in your provider credentials.
# Expect OPENROUTER_API_KEY to be pre-exported in the shell.
: "${OPENROUTER_API_KEY:?OPENROUTER_API_KEY is required. Run: export OPENROUTER_API_KEY=...}"
export OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
export OPENROUTER_MODEL="moonshotai/kimi-k2.5"
# Optional: dedicated model for Router / Planner / SkillSelector.
# If empty, it falls back to OPENROUTER_MODEL.
export OPENROUTER_MODEL_FOR_ORCHESTRATOR="openai/gpt-5.2"

# ===== WeKnora access (required) =====
# WEKNORA_API_KEY is your tenant/workspace key from WeKnora.
# It will be used as the auth key for subsequent WeKnora API calls (HTTP header: X-API-Key).
# Expect WEKNORA_API_KEY to be pre-exported in the shell.
: "${WEKNORA_API_KEY:?WEKNORA_API_KEY is required. Run: export WEKNORA_API_KEY=...}"
export WEKNORA_BASE_URL="http://localhost:8080"
export WEKNORA_KB_NAME="test"
export WEKNORA_AGENT_NAME="个人助理"
export WEKNORA_SESSION_ID="seneschal-session"

# ===== Brave Search (web search for Worker agent) =====
# Required when Worker needs online news/web search.
# Get API key from https://brave.com/search/api/
export BRAVE_API_KEY="${BRAVE_API_KEY:-}"
# Optional overrides
export BRAVE_SEARCH_BASE_URL="https://api.search.brave.com/res/v1/web/search"
export BRAVE_SEARCH_MAX_RESULTS="5"

# ===== Mobile Executor (local runner used by steward mobi tools) =====
# Core selector
# mobiagent | uitars | qwen | autoglm
export MOBILE_PROVIDER="mobiagent"      
<!-- export MOBILE_OUTPUT_DIR="outputs/mobile_exec" -->

# Device
# Use "mock" for non-device environments, or Android/Harmony on real devices.
export MOBILE_DEVICE_TYPE="Android"          # mock | Android | Harmony
export MOBILE_DEVICE_ID=""                   # optional adb endpoint, e.g. 127.0.0.1:5555

# Global model params (applies to selected provider unless provider-specific override is set)
export MOBILE_API_BASE=""                    # optional global override
export MOBILE_API_KEY=""                     # optional global override
export MOBILE_MODEL=""                       # optional global override
export MOBILE_TEMPERATURE="0.0"
export MOBILE_MAX_STEPS="15"
export MOBILE_DRAW="0"

# Provider-specific example (MOBIAGENT path)
# If MOBILE_API_BASE is empty, executor will fallback to this legacy pair:
# http://MOBIAGENT_SERVER_IP:MOBIAGENT_SERVER_DECIDER_PORT/v1
export MOBILE_MOBIAGENT_ENABLE_PLANNING="0"
export MOBILE_MOBIAGENT_USE_E2E="1"
export MOBILE_MOBIAGENT_DECIDER_MODEL="MobiMind-1.5-4B"
export MOBILE_MOBIAGENT_GROUNDER_MODEL="MobiMind-1.5-4B"
export MOBILE_MOBIAGENT_PLANNER_MODEL="Qwen3-VL-30B-A3B-Instruct"
# ===== Legacy MobiAgent envs (kept for backward compatibility) =====
# New executor can still read these when MOBILE_* keys are absent.
export MOBILE_MOBIAGENT_SERVER_IP="166.111.53.96"
export MOBILE_MOBIAGENT_DECIDER_PORT="7003"
export MOBILE_MOBIAGENT_GROUNDER_PORT="7003"
export MOBILE_MOBIAGENT_PLANNER_PORT="7002"
export MOBILE_MOBIAGENT_API_KEY="${MOBIAGENT_API_KEY:-}"
export MOBILE_DEVICE="Android"

# Provider-specific example (UITARS)
# export MOBILE_PROVIDER="uitars"
# export MOBILE_UITARS_API_BASE="http://127.0.0.1:8000/v1"
# export MOBILE_UITARS_MODEL="UI-TARS-1.5-7B"
# export MOBILE_UITARS_STEP_DELAY="2.0"

# Provider-specific example (QWEN)
# export MOBILE_PROVIDER="qwen"
# export MOBILE_QWEN_API_BASE="http://127.0.0.1:8080/v1"
# export MOBILE_QWEN_MODEL="Qwen3-VL-30B-A3B-Instruct"
# export MOBILE_QWEN_TEMPERATURE="0.0"

# Provider-specific example (AUTOGLM)
# export MOBILE_PROVIDER="autoglm"
# export MOBILE_AUTOGLM_API_BASE="http://127.0.0.1:8000/v1"
# export MOBILE_AUTOGLM_MODEL="autoglm-phone-9b"
# export MOBILE_AUTOGLM_MAX_TOKENS="3000"
# export MOBILE_AUTOGLM_TOP_P="0.85"
# export MOBILE_AUTOGLM_FREQUENCY_PENALTY="0.2"




# ===== Multi-agent routing =====
# router/intelligent: enable Router + Planner + Executor orchestration
# legacy modes are still supported by request.mode = worker/steward/auto
export SENESCHAL_ROUTING_DEFAULT_MODE="router"
export SENESCHAL_ROUTING_STRATEGY="llm_rule_hybrid"
export SENESCHAL_ALLOW_LEGACY_MODE="1"
export SENESCHAL_ROUTING_MAX_SUBTASKS="4"
export SENESCHAL_ROUTING_MAX_DEPTH="2"
export SENESCHAL_ROUTER_TIMEOUT_S="120"
export SENESCHAL_PLANNER_TIMEOUT_S="120"
export SENESCHAL_SUBTASK_TIMEOUT_S="300"
export SENESCHAL_SKILL_SELECTOR_TIMEOUT_S="120"

export SENESCHAL_CHAT_SESSION_ROOT=".mobiclaw/session"

# ===== Feishu bot event ingress =====
# Recommended for local development: long-connection mode does not require public IP.
# Allowed values:
# - webhook: only accept HTTP callback at /api/v1/feishu/events
# - long_conn: only long connection client
# - both: enable both webhook + long connection (default)
# - auto: try long connection when FEISHU_APP_ID/FEISHU_APP_SECRET are present
export FEISHU_EVENT_TRANSPORT="both"

# Keep these credentials in shell export for safety. If missing, gateway will print warning
# and skip long connection startup.
export FEISHU_APP_ID="${FEISHU_APP_ID:-}"
export FEISHU_APP_SECRET="${FEISHU_APP_SECRET:-}"

# Optional: used by webhook verification and/or encrypted event payload check.
export FEISHU_VERIFICATION_TOKEN="${FEISHU_VERIFICATION_TOKEN:-}"
export FEISHU_ENCRYPT_KEY="${FEISHU_ENCRYPT_KEY:-}"

# ===== WeKnora model mappings (used by configs/*.json placeholders) =====
# IDs/Names should match your WeKnora model records.
# Rerank and Embedding keep dedicated credentials; KnowledgeQA/VLM reuse OPENROUTER_*.

# Rerank model
export WEKNORA_MODEL_RERANK_ID="96629987-710e-4898-8777-42d60e73b959"
export WEKNORA_MODEL_RERANK_NAME="bge-reranker-v2-m3"
export WEKNORA_MODEL_RERANK_API_KEY="${WEKNORA_MODEL_RERANK_API_KEY:-}"
export WEKNORA_MODEL_RERANK_BASE_URL="http://0.0.0.0:8001"

# Primary KnowledgeQA model
export WEKNORA_MODEL_KNOWLEDGE_QA_ID="c89ac8fe-3bda-4e2d-a009-8a3da3ee7b00"
export WEKNORA_MODEL_KNOWLEDGE_QA_NAME="qwen/qwen3.5-397b-a17b"

# Alternate KnowledgeQA model (tenant conversation config)
export WEKNORA_MODEL_KNOWLEDGE_QA_ALT_ID="63b17e5d-eb48-4d53-bfbd-6b6fb4cf6fda"
export WEKNORA_MODEL_KNOWLEDGE_QA_ALT_NAME="qwen/qwen3.5-397b-a17b"

# VLM model
export WEKNORA_MODEL_VLM_ID="63f74606-e4d2-4501-99b5-831ace734e6d"
export WEKNORA_MODEL_VLM_NAME="qwen/qwen3.5-397b-a17b"

# Embedding model (usually independent endpoint/key)
export WEKNORA_MODEL_EMBEDDING_ID="930a63a1-7584-4849-8570-a78c92007d7b"
export WEKNORA_MODEL_EMBEDDING_NAME="openai/text-embedding-3-large"
export WEKNORA_MODEL_EMBEDDING_API_KEY="$OPENROUTER_API_KEY"
export WEKNORA_MODEL_EMBEDDING_BASE_URL="https://openrouter.ai/api/v1"

# Memory
# uncomment the following to disable memory and rag
# export SENESCHAL_MEMORY_ENABLED="0"
# export SENESCHAL_RAG_STORE_HISTORY="0"

# Scheduled tasks
# uncomment the following to disable scheduled tasks
# export SENESCHAL_SCHEDULE_ENABLED="0"
# JSON file path for persisting scheduled tasks (supports ~ expansion)
export SENESCHAL_SCHEDULE_STORE_PATH="~/.seneschal/schedules.json"
